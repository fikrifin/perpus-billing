<Window x:Class="PerpusBilling.WindowsClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Perpus Billing Client" Height="720" Width="1100"
        Background="#0f1f1b">
  <Grid Margin="32">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Padding="20" CornerRadius="22" Background="#19362e">
      <DockPanel>
        <StackPanel>
          <TextBlock x:Name="BusinessNameText" Text="Perpustakaan Daerah" Foreground="#9ee5b2" FontWeight="SemiBold" FontSize="14" />
          <TextBlock Text="Perpus Billing Client" Foreground="White" FontSize="34" FontWeight="Bold" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
          <TextBlock x:Name="ComputerCodeText" Text="PC-01" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Right" />
          <TextBlock x:Name="ServerStatusText" Text="Menghubungkan..." Foreground="#c5d7d0" HorizontalAlignment="Right" />
        </StackPanel>
      </DockPanel>
    </Border>

    <Grid Grid.Row="1" Margin="0,28,0,28">
      <Border x:Name="LoginPanel" Padding="34" CornerRadius="26" Background="#f8fbf7" MaxWidth="520" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel>
          <TextBlock Text="Login Pengguna" FontSize="28" FontWeight="Bold" Foreground="#17231f" />
          <TextBlock x:Name="MessageText" Text="Silakan login untuk memakai komputer." Foreground="#52615b" Margin="0,6,0,24" TextWrapping="Wrap" />
          <TextBlock Text="Username" FontWeight="SemiBold" />
          <TextBox x:Name="UsernameBox" Height="44" Margin="0,6,0,14" FontSize="16" />
          <TextBlock Text="Password" FontWeight="SemiBold" />
          <PasswordBox x:Name="PasswordBox" Height="44" Margin="0,6,0,22" FontSize="16" />
          <Button x:Name="LoginButton" Content="Mulai Pakai Komputer" Height="48" FontSize="16" FontWeight="Bold" Click="LoginButton_Click" Background="#1f6f4a" Foreground="White" />
          <TextBlock x:Name="ErrorText" Foreground="#b42318" Margin="0,16,0,0" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border x:Name="SessionPanel" Visibility="Collapsed" Padding="34" CornerRadius="26" Background="#f8fbf7" MaxWidth="680" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel>
          <TextBlock Text="Session Aktif" FontSize="28" FontWeight="Bold" Foreground="#17231f" />
          <TextBlock x:Name="SessionUserText" Text="-" Foreground="#52615b" Margin="0,6,0,20" />
          <TextBlock x:Name="RemainingText" Text="00:00" FontSize="64" FontWeight="Bold" Foreground="#1f6f4a" HorizontalAlignment="Center" />
          <ProgressBar x:Name="UsageProgress" Height="16" Minimum="0" Maximum="100" Margin="0,20,0,18" />
          <Button Content="Logout / Selesai" Height="46" Click="StopButton_Click" Background="#eef4ef" Foreground="#1f4b38" />
        </StackPanel>
      </Border>

      <Border x:Name="WarningPanel" Visibility="Collapsed" Padding="34" CornerRadius="26" Background="#fff3c4" MaxWidth="700" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel>
          <TextBlock x:Name="WarningTitleText" Text="Waktu Habis" FontSize="34" FontWeight="Bold" Foreground="#8a5a00" />
          <TextBlock x:Name="WarningMessageText" Text="Komputer akan shutdown." Foreground="#6b4b00" Margin="0,8,0,20" TextWrapping="Wrap" />
          <TextBlock x:Name="WarningCountdownText" Text="60" FontSize="72" FontWeight="Bold" Foreground="#8a5a00" HorizontalAlignment="Center" />
        </StackPanel>
      </Border>
    </Grid>

    <TextBlock Grid.Row="2" x:Name="FooterText" Foreground="#c5d7d0" TextAlignment="Center" />
  </Grid>
</Window>
