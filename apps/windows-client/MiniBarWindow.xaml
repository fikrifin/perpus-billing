<Window x:Class="PerpusBilling.WindowsClient.MiniBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="250"
        Height="48"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False">
  <Border x:Name="RootBorder" CornerRadius="16" Background="#E0192024" BorderBrush="#5536C98A" BorderThickness="1" Padding="12,7">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Border x:Name="StatusDot" Width="10" Height="10" CornerRadius="999" Background="#36C98A" VerticalAlignment="Center" />

      <TextBlock x:Name="MiniTitleText"
                 Grid.Column="1"
                 Margin="10,0,0,0"
                 Text="PC-01"
                 Foreground="#D7F5E4"
                 FontSize="12"
                 FontWeight="SemiBold"
                 VerticalAlignment="Center" />

      <TextBlock x:Name="MiniRemainingText"
                 Grid.Column="2"
                 Margin="14,0,0,0"
                 Text="59:59"
                 Foreground="White"
                 FontSize="18"
                 FontWeight="Bold"
                 VerticalAlignment="Center" />
    </Grid>
  </Border>
</Window>
