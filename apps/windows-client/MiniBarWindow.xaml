<Window x:Class="PerpusBilling.WindowsClient.MiniBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="222"
        Height="40"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False">
  <Border x:Name="RootBorder" CornerRadius="14" Background="#E0192024" BorderBrush="#5536C98A" BorderThickness="1" Padding="10,5">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Border x:Name="StatusDot" Width="8" Height="8" CornerRadius="999" Background="#36C98A" VerticalAlignment="Center" />

      <TextBlock x:Name="MiniTitleText"
                 Grid.Column="1"
                 Margin="8,0,0,0"
                 Text="PC-01"
                 Foreground="#D7F5E4"
                 FontSize="11"
                 FontWeight="SemiBold"
                 VerticalAlignment="Center" />

      <TextBlock x:Name="MiniRemainingText"
                 Grid.Column="2"
                 Margin="10,0,0,0"
                 Text="59:59"
                 Foreground="White"
                 FontSize="16"
                 FontWeight="Bold"
                 VerticalAlignment="Center" />

      <Button x:Name="MiniExitButton"
              Grid.Column="3"
              Margin="10,0,0,0"
              Width="26"
              Height="26"
              Content="⏻"
              FontSize="12"
              FontWeight="Bold"
              Cursor="Hand"
              Background="#22FFFFFF"
              Foreground="White"
              BorderBrush="#33FFFFFF"
              Click="MiniExitButton_Click" />
    </Grid>
  </Border>
</Window>
